<html>
    <head>
        <title>My Cart</title>
    </head>
    <body>
        <h1>My Cart</h1>
        <ul>
            <%for(i of book_list){%>
                <li>
                    <p><strong>Title: </strong><%=i.title%></p>
                    <p><strong>Author: </strong><%=i.author%></p>
                    <p><strong>Reviews: </strong><%=i.isbn%></p>
                    <p><strong>Price: </strong><%=i.price%></p>
                    <p><strong>Quantity: </strong><%=i.quantity%></p>
                    <p><strong>Quantity: </strong>
                        <input type="number" name="quantity_<%= i._id %>" value="<%= i.quantity %>" min="1" required>
                    </p>
                    <form action="/update-cart-quantity" method="POST">
                        <button type="submit">Update</button>
                    </form>
                    <button><a href="/delete-cart-book/?id=<%=i._id%>">Delete Book</a></button>
                </li>
            <%}%>
        </ul>
    </body>
</html>