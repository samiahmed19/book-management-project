<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cart</title>
</head>
<body>
    <h1>Your Cart</h1>

    <ul>
        <% for (const book of books) { %>
            <li>
                <%= book.title %> - Quantity: <%= book.quantity %> - Price per unit: $<%= book.price %> - Subtotal: $<%= book.quantity * book.price %>
            </li>
        <% } %>
    </ul>

    <p>Total Price: $<%= total_price %></p>

    <a href="/my-carts">Back to Cart</a>
</body>
</html>
